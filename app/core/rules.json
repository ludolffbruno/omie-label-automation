{
    "CLARO": {
        "name": "Claro Dividida",
        "template": "claro_dividida",
        "conditions": [
            {
                "field": "cliente",
                "operator": "contains",
                "value": "CLARO"
            }
        ],
        "mappings": {
            "oc": {
                "source": "observacoes",
                "regex": "\\b(?:OC|O/C|ORDEM\\s+DE\\s+COMPRA|PEDIDO\\s+DE\\s+COMPRA|PEDIDO\\s+COMPRA|PEDIDO)\\b\\s*[:=\\-\\s]?\\s*([A-Za-z0-9./\\-]+)"
            },
            "requisitante": {
                "source": "observacoes",
                "regex": "(?:\\bA/C\\b|\\bAC\\s+DE\\b|\\bAOS\\s+CUIDADOS\\s+DE\\b|\\bREQUISITANTE\\b|\\bSOLICITANTE\\b)\\s*[:\\-\\s]?\\s*([^|\\n;]+)"
            },
            "numero_ordem": {
                "source": "observacoes",
                "regex": "(?:\\bN[繙簞O]?\\s*(?:DO\\s*)?PEDIDO\\b|\\bNUMERO\\s+(?:DO\\s*)?PEDIDO\\b|\\bPEDIDO\\b|\\bN[繙簞O]?\\s*ORDEM\\b|\\bNUMERO\\s+DA\\s+ORDEM\\b|\\bNRO\\s*ORDEM\\b|\\bORDEM\\b)\\s*[:=\\-\\s]?\\s*([A-Za-z0-9./\\-]+)"
            }
        },
        "sort_order": 20
    },
